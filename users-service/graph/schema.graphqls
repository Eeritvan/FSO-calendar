# GraphQL schema example
#
# https://gqlgen.com/getting-started/

scalar UUID

type User {
  id: UUID!
  username: String!
  password: String!
  totp: String
}

type Query {
  users: [User!]!
}

input NewUserInput {
  username: String!
  password: String!
}

input LoginInput {
  username: String!
  password: String!
  totp: String
}

type Mutation {
  createUser(input: NewUserInput!): User!
  login(input: LoginInput!): Boolean!
}
